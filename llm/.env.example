# === LLM Stack - Common Environment Variables ===
# Copy this file to .env and fill in actual values.

# Neo4j credentials
NEO4J_PASSWORD=your_secure_password_here

# Redis credentials
REDIS_PASSWORD=your_secure_password_here

# Application image tag (overridden per environment)
IMAGE_TAG=staging

# Host ports for application services
LLM_BACKEND_PORT=8002
LLM_FRONTEND_PORT=3000
