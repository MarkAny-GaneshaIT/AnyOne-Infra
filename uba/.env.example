# === UBA Stack - Common Environment Variables ===
# Copy this file to .env and fill in actual values.

# Kafka cluster ID (unique per cluster, required for KRaft mode)
KAFKA_CLUSTER_ID=EmptNWtoR4GGWx-BH6nGLQ

# Kafka JVM heap size
KAFKA_HEAP_OPTS=-Xmx512m -Xms512m

# Application image tag (overridden per environment)
IMAGE_TAG=staging

# UBA backend port on the host
UBA_BACKEND_PORT=8001
